@model ErrorViewModel
@{
    ViewData["Title"] = "System Error";
}

<div class="row justify-content-center hero-section">
    <div class="col-md-6 text-center">
        <div class="mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#dc3545" class="bi bi-exclamation-octagon" viewBox="0 0 16 16">
                <path d="M4.54.146A.5.5 0 0 1 4.893 0h6.214a.5.5 0 0 1 .353.146l4.394 4.394a.5.5 0 0 1 .146.353v6.214a.5.5 0 0 1-.146.353l-4.394 4.394a.5.5 0 0 1-.353.146H4.893a.5.5 0 0 1-.353-.146L.146 11.46A.5.5 0 0 1 0 11.107V4.893a.5.5 0 0 1 .146-.353L4.54.146zM5.1 1 1 5.1v5.8L5.1 15h5.8l4.1-4.1V5.1L10.9 1H5.1z" />
                <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z" />
            </svg>
        </div>

        <h1 class="fw-bold">Something went wrong</h1>
        <p class="text-muted">The authentication request could not be completed.</p>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="card bg-light border-0 text-start mt-4">
                <div class="card-body">
                    <h6 class="text-danger fw-bold text-uppercase small">Protocol Error</h6>
                    <p class="mb-1"><strong>Code:</strong> <code>@Model.Error</code></p>
                    @if (!string.IsNullOrEmpty(Model.ErrorDescription))
                    {
                        <p class="mb-0"><strong>Description:</strong> @Model.ErrorDescription</p>
                    }
                </div>
            </div>
        }

        <div class="mt-5">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">Return Home</a>
            <button onclick="window.location.reload()" class="btn btn-outline-secondary px-4">Try Again</button>
        </div>

        @if (Model.ShowRequestId)
        {
            <p class="mt-4 small text-muted">
                Trace ID: <span class="font-monospace">@Model.RequestId</span>
            </p>
        }
    </div>
</div>